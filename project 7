#include <stdio.h>

int main(void) {
    int a, b, c, largest;

    printf("Enter three numbers: ");
    if (scanf("%d %d %d", &a, &b, &c) != 3) {
        printf("Invalid input.\n");
        return 1;
    }

    largest = a;
    if (b > largest) largest = b;
    if (c > largest) largest = c;

    printf("The largest number is %d\n", largest);
    return 0;
}